{
  "name": "douyin-qr-c",
  "version-string": "0.1.0",
  "dependencies": [
    {
      "name": "ffmpeg",
      "default-features": false,
      "features": [
        "avcodec",
        "avformat",
        "swresample",
        "swscale"
      ]
    },
    "sdl2",
    "mchehab-zbar",
    "libqrencode",
    {
      "name": "qtbase",
      "default-features": false,
      "features": [
        "gui",
        "widgets",
        "jpeg",
        "png",
        "network"
      ]
    }
  ]
}
